# Copy to .env or set in your host. The app does NOT read Supabase tables unless you use Postgres below.

# SQLite (default):
# DATABASE_URL=sqlite:///./fruit_vegetable_costs.db

# Supabase: use the Postgres connection string only (Database → Connection string → URI).
# Transaction pooler (port 6543) is recommended for APIs. Append ?sslmode=require if needed.
# After switching, restart the server and re-upload sales + P&L (empty Supabase DB has no rows).
# DATABASE_URL=postgresql://postgres.[ref]:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Branding (optional). Do not set ERP_COMPANY_TAGLINE to the same text as ERP_COMPANY_NAME.
# ERP_COMPANY_NAME=Your Company Name
# ERP_COMPANY_TAGLINE=
# ERP_LOGO_URL=https://xxx.supabase.co/storage/v1/object/public/bucket/logo.png
