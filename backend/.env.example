# Copy to .env or set in your host (Railway, Fly, DigitalOcean, etc.)

# SQLite (default): leave unset or use:
# DATABASE_URL=sqlite:///./fruit_vegetable_costs.db

# Supabase Postgres (Settings → Database → URI). Prefer pooler + ssl:
# DATABASE_URL=postgresql://postgres.[project-ref]:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Sidebar / browser title (replaces hardcoded "Purple Patch" branding)
# ERP_COMPANY_NAME=Your Company Name
# ERP_COMPANY_TAGLINE=Optional short line under the name
# ERP_LOGO_URL=https://your-project.supabase.co/storage/v1/object/public/logos/logo.png
